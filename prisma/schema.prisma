generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  logo       String?
  logoUrl    String?  @default("")
  address    String?  @default("")
  city       String?  @default("")
  province   String?  @default("")
  postalCode String?  @default("")
  nif        String?  @default("")
  phone      String?  @default("")
  email      String?  @default("")
  website    String?  @default("")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users         User[]
  sedes         Sede[]
  professionals Professional[]
  plans         Plan[]
  holidays      Holiday[]
  subscription  Subscription?
  payments      Payment[]
  avisos        Aviso[]
  billClientes  BillCliente[]
  billCatalogo  BillCatalogo[]
  billRegistros BillRegistro[]
  billConfig    BillConfig?
  billFacturaSeq BillFacturaSeq?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  image     String?
  role      String   @default("USER") // SUPER_ADMIN | COMPANY_ADMIN | USER
  companyId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company?  @relation(fields: [companyId], references: [id])
}

model Subscription {
  id                String   @id @default(cuid())
  companyId         String   @unique
  planName          String   @default("BASIC") // BASIC | PRO | ENTERPRISE
  billingMethod     String   @default("MONTHLY") // MONTHLY | QUARTERLY | ANNUAL
  price             Float    @default(29.99)
  currency          String   @default("EUR")
  status            String   @default("TRIAL") // ACTIVE | PAST_DUE | CANCELLED | TRIAL
  trialEndsAt       DateTime?
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd  DateTime @default(now())
  maxProfessionals  Int      @default(5)
  maxSedes          Int      @default(3)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  payments Payment[]
}

model Payment {
  id              String    @id @default(cuid())
  subscriptionId  String
  companyId       String
  amount          Float
  currency        String    @default("EUR")
  status          String     @default("PENDING") // PENDING | PAID | FAILED | REFUNDED | OVERDUE
  paymentDate     DateTime?
  dueDate         DateTime
  method          String     @default("CARD") // CARD | TRANSFER | CASH
  invoiceNumber   String?
  concept         String?    @default("Suscripción mensual")
  taxRate         Float      @default(21.0)
  taxAmount       Float      @default(0)
  subtotal        Float      @default(0)
  periodStart     DateTime?
  periodEnd       DateTime?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime   @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  company      Company     @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
}

model Sede {
  id               String   @id @default(cuid())
  companyId        String
  name             String
  city             String   @default("")
  province         String   @default("")
  task             String   @default("")
  email            String   @default("")
  phone            String   @default("")
  morningEnabled   Boolean  @default(true)
  afternoonEnabled Boolean  @default(true)
  color            String   @default("#3b82f6")
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plans   Plan[]
  avisos  Aviso[]

  @@index([companyId])
}

model Professional {
  id            String   @id @default(cuid())
  companyId     String
  firstName     String
  lastName      String
  alias         String
  type          String   @default("USER") // USER | ADMINISTRADOR
  category      String   @default("")
  username      String   @default("")
  email         String   @default("")
  phone         String   @default("")
  permissions   String   @default("") // comma-separated tasks (per in Firebase)
  assignedSedes String   @default("") // comma-separated sede names
  startDate     String   @default("") // ini date string (fini in Firebase)
  endDate       String   @default("INDEFINIDO")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  avisos  Aviso[]

  @@unique([companyId, alias])
  @@index([companyId])
}

model Plan {
  id                String   @id @default(cuid())
  companyId         String
  sedeId            String
  date              String   // YYYY-MM-DD
  turn              String   // MANANA | TARDE
  professionalAlias String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sede    Sede    @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([sedeId, date, turn])
  @@index([companyId, date])
  @@index([companyId, sedeId])
}

model Holiday {
  id        String   @id @default(cuid())
  companyId String
  province  String
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, province, date])
  @@index([companyId])
}

model Aviso {
  id              String   @id @default(cuid())
  companyId       String
  date            String   // YYYY-MM-DD
  professionalId  String?  // nullable: sede-level absences don't need a professional
  sedeId          String
  turn            String   // M | T
  reason          String   @default("") // BAJA | FORMACION | PERMISO | VACACIONES | custom
  createdAt       DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  sede         Sede          @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([professionalId])
  @@index([sedeId])
}

// ═══════════════════════════════════════════
// BILL by Método — Facturación independiente
// ═══════════════════════════════════════════

model BillCliente {
  id          String   @id @default(cuid())
  companyId   String
  nombre      String
  cif         String   @default("")
  dir         String   @default("")
  cp          String   @default("")
  ciudad      String   @default("")
  prov        String   @default("")
  mail        String   @default("")
  tel         String   @default("")
  customData  String   @default("") // JSON: custom field values
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  registros BillRegistro[]
  catalogo   BillCatalogo[]

  @@index([companyId])
}

model BillCatalogo {
  id          String   @id @default(cuid())
  companyId   String
  clienteId   String?  // optional: client-specific pricing
  c1          String   // concept group
  c2          String   // concept service
  coste       Float    @default(0)
  inc         Float    @default(0) // increment %
  final       Float    @default(0) // final price
  customData  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cliente BillCliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([clienteId])
}

model BillRegistro {
  id                String   @id @default(cuid())
  companyId         String
  fecha             String   // YYYY-MM-DD
  clienteId         String?  // FK
  cliente           String   @default("") // denormalized name
  c1                String   @default("") // concept group
  c2                String   @default("") // concept service
  cant              Int      @default(1)
  precioUnitario    Float    @default(0)
  obs               String   @default("")
  pasadoRegistro    Boolean  @default(false) // transferred from entrada
  facturado         Boolean  @default(false) // invoiced
  customData        String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteRel  BillCliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([clienteId])
  @@index([fecha])
  @@index([pasadoRegistro])
  @@index([facturado])
}

model BillConfig {
  id                String   @id @default(cuid())
  companyId         String   @unique
  companyFullName   String   @default("")
  companyAddress    String   @default("")
  companyCity       String   @default("")
  companyProvince   String   @default("")
  companyCif        String   @default("")
  logo              String   @default("") // base64
  currency          String   @default("€")
  defaultIva        Float    @default(21)
  appName           String   @default("BILL by Método")
  sectionEntrada    String   @default("ENTRADA")
  sectionRegistros  String   @default("REGISTROS")
  sectionClientes   String   @default("CLIENTES")
  sectionCatalogo   String   @default("CATÁLOGO")
  sectionFacturas   String   @default("FACTURAS")
  fieldsEntrada     String   @default("") // JSON: FieldDef[]
  fieldsClientes    String   @default("")
  fieldsCatalogo    String   @default("")
  fieldsRegistros   String   @default("")
  fieldsFacturas    String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model BillFacturaSeq {
  id        String   @id @default(cuid())
  companyId String   @unique
  seq       Int      @default(1)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
